rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: transactions
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, < 100 chars)
    //   - amount: number (required, >= 0)
    //   - date: string (required, <= 20 chars)
    //   - type: string (required, 'income' or 'expense')
    //   - uid: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: denaPaona
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, < 100 chars)
    //   - phone: string (required, <= 20 chars)
    //   - address: string (required, <= 200 chars)
    //   - paona: number (required, >= 0)
    //   - dena: number (required, >= 0)
    //   - uid: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: savings
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, < 100 chars)
    //   - amount: number (required, >= 0)
    //   - date: string (required, <= 20 chars)
    //   - uid: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: notes
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, < 200 chars)
    //   - content: string (required, < 5000 chars)
    //   - date: string (required, <= 20 chars)
    //   - uid: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //   - color: string (required, <= 20 chars)
    //
    // Collection: fards
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, < 100 chars)
    //   - items: list (required, <= 100 items)
    //   - date: string (required, <= 20 chars)
    //   - uid: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    // Domain Validators
    function isValidTransaction(data) {
      return hasRequiredFields(['title', 'amount', 'date', 'type', 'uid', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.amount is number && data.amount >= 0 &&
             data.date is string && data.date.size() <= 20 &&
             data.type in ['income', 'expense'] &&
             data.uid is string && data.uid.size() > 0 &&
             data.createdAt is timestamp;
    }

    function isValidDenaPaona(data) {
      return hasRequiredFields(['name', 'phone', 'address', 'paona', 'dena', 'uid', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.address is string && data.address.size() <= 200 &&
             data.paona is number && data.paona >= 0 &&
             data.dena is number && data.dena >= 0 &&
             data.uid is string && data.uid.size() > 0 &&
             data.createdAt is timestamp;
    }

    function isValidSaving(data) {
      return hasRequiredFields(['title', 'amount', 'date', 'uid', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.amount is number && data.amount >= 0 &&
             data.date is string && data.date.size() <= 20 &&
             data.uid is string && data.uid.size() > 0 &&
             data.createdAt is timestamp;
    }

    function isValidNote(data) {
      return hasRequiredFields(['title', 'content', 'date', 'uid', 'createdAt', 'color']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() < 5000 &&
             data.date is string && data.date.size() <= 20 &&
             data.uid is string && data.uid.size() > 0 &&
             data.createdAt is timestamp &&
             data.color is string && data.color.size() <= 50;
    }

    function isValidAlarm(data) {
      return hasRequiredFields(['title', 'time', 'isActive', 'uid', 'createdAt']) &&
             data.title is string && data.title.size() < 100 &&
             data.time is string && data.time.size() <= 5 &&
             data.isActive is bool &&
             data.uid is string && data.uid.size() > 0 &&
             data.createdAt is timestamp;
    }

    function isValidFardItems(items) {
      return items is list && items.size() <= 100;
    }

    function isValidFard(data) {
      return hasRequiredFields(['title', 'items', 'date', 'uid', 'createdAt', 'updatedAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             isValidFardItems(data.items) &&
             data.date is string && data.date.size() <= 20 &&
             data.uid is string && data.uid.size() > 0 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidSavingsAccount(data) {
      return hasRequiredFields(['name', 'accountNumber', 'balance', 'uid', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.accountNumber is string && data.accountNumber.size() > 0 && data.accountNumber.size() < 50 &&
             (!('address' in data) || (data.address is string && data.address.size() <= 200)) &&
             data.balance is number &&
             data.uid is string && data.uid.size() > 0 &&
             data.createdAt is timestamp;
    }

    function isValidDenaPaonaTransaction(data) {
      return hasRequiredFields(['personId', 'amount', 'type', 'uid', 'createdAt']) &&
             data.personId is string && data.personId.size() > 0 &&
             data.amount is number && data.amount >= 0 &&
             data.type in ['paona_increase', 'paona_decrease', 'dena_increase', 'dena_decrease'] &&
             (!('note' in data) || (data.note is string && data.note.size() <= 500)) &&
             data.uid is string && data.uid.size() > 0 &&
             data.createdAt is timestamp;
    }

    function isValidSavingsTransaction(data) {
      return hasRequiredFields(['accountId', 'amount', 'type', 'uid', 'createdAt']) &&
             data.accountId is string && data.accountId.size() > 0 &&
             data.amount is number && data.amount >= 0 &&
             data.type in ['deposit', 'withdrawal'] &&
             (!('note' in data) || (data.note is string && data.note.size() <= 500)) &&
             data.uid is string && data.uid.size() > 0 &&
             data.createdAt is timestamp;
    }

    match /transactions/{transactionId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidTransaction(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /denaPaona/{recordId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidDenaPaona(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidDenaPaona(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /denaPaonaTransactions/{txId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidDenaPaonaTransaction(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidDenaPaonaTransaction(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /savings/{savingId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSaving(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidSaving(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /savings_accounts/{accountId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSavingsAccount(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidSavingsAccount(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /savingsTransactions/{txId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSavingsTransaction(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidSavingsTransaction(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /notes/{noteId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidNote(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidNote(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /alarms/{alarmId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidAlarm(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidAlarm(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /fards/{fardId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidFard(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidFard(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /admin_ads/{adId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin can write from backend
    }
  }
}
